# ── Hub の実行時設定 ─────────────────────────────────────────
# SQLite の実体パス（web / worker が共有する）
DB_PATH=/data/harness.db

# 分析用 Claude Code の設定ディレクトリ分離（Hub の ~/.claude を汚染しない）
CLAUDE_CONFIG_DIR=/data/claude-config

# ── Claude Code サブスク認証 ─────────────────────────────────
# `claude setup-token` で発行した長期トークンを注入する。
# 注意: 環境変数名は Phase 2 冒頭の実機素振りで確定する（暫定名）。
CLAUDE_CODE_OAUTH_TOKEN=

# ── SSH（Hub → 開発機）─────────────────────────────────────
# 専用鍵の Hub 側パス。docker-compose で worker に :ro マウントする。
HARNESS_SSH_KEY=/secrets/ssh_key

# ── web ─────────────────────────────────────────────────────
# Next.js は 127.0.0.1 のみに publish（外部到達は nginx 経由のみ）
WEB_PORT=3000

# ── 収集パラメータ（既定値。machines/settings で上書き可）──────
# 直近何セッションを assistant 応答込みで全文収集するか
RECENT_FULL_SESSIONS=5
# workspace 走査の最大深度
WORKSPACE_MAX_DEPTH=6
# Tier1 生増分の消費後猶予日数
TIER1_GRACE_DAYS=7
