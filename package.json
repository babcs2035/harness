{
  "name": "harness",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Code ハーネス育成アプリ（個人用・Hub 集約型）",
  "packageManager": "pnpm@11.13.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r build",
    "check": "biome ci . && pnpm -r run typecheck",
    "db:init": "pnpm --filter @harness/shared exec tsx src/init-db.ts",
    "prepare": "husky",
    "typecheck": "pnpm --filter @harness/shared build && pnpm -r run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "husky": "^9.1.7",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  }
}
